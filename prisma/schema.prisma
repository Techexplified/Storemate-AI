// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ChatbotConfig {
  id              String @id @default(cuid())
  shop            String @unique
  botName         String @default("Aria")
  personalityTone String @default("friendly")
  avatarPreset    String @default("green")
  logoUrl         String?
  welcomeMessage  String?
  starterPrompts  String?
  brandColor      String? @default("#00A460")
  language        String? @default("en")
  capProducts      Boolean @default(true)
  capOrderTracking Boolean @default(true)
  capPolicies      Boolean @default(true)
  capFaqs          Boolean @default(true)
}

model MerchantConfig {
  id            String    @id @default(cuid())
  shop          String    @unique
  supportEmail  String?
  supportUrl    String?
  productCache  String?
  cacheSyncedAt DateTime?
}

model Policy {
  id        String   @id @default(cuid())
  shop      String
  name      String
  text      String
  createdAt DateTime @default(now())

  @@index([shop])
}

model Faq {
  id        String   @id @default(cuid())
  shop      String
  question  String
  answer    String
  createdAt DateTime @default(now())

  @@index([shop])
}

model Conversation {
  id        String   @id @default(cuid())
  shop      String
  sessionId String
  role      String
  message   String
  createdAt DateTime @default(now())
  customerName  String?  @default("Guest")
  customerEmail String?

  @@index([shop])
}